load("@aspect_rules_js//npm:defs.bzl", "npm_package")
load("@aspect_rules_ts//ts:defs.bzl", "ts_config", "ts_project")

package(default_visibility = ["//visibility:public"])

ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
    visibility = ["//visibility:public"],
)

ts_project(
    name = "gcsapi_ts",
    srcs = ["gcsapi.ts"],
    declaration = True,
    source_map = True,
    tsconfig = ":tsconfig",
)

npm_package(
    name = "pkg",
    srcs = [
        "package.json",
        ":gcsapi_ts",
    ],
)
