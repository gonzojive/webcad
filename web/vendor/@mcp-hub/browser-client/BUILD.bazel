# gazelle:ignore
# gazelle:exclude src
load("@aspect_rules_ts//ts:defs.bzl", "ts_config", "ts_project")
load("@aspect_rules_js//npm:defs.bzl", "npm_package")

package(default_visibility = ["//visibility:public"])

ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
)

ts_project(
    name = "browser-client_ts",
    srcs = [
        "src/client.ts",
        "src/consent.ts",
        "src/index.ts",
        "src/transport.ts",
        "src/types.ts",
    ],
    declaration = True,
    declaration_map = True,
    out_dir = "dist",
    root_dir = "src",
    source_map = True,
    tsconfig = ":tsconfig",
)

npm_package(
    name = "browser-client",
    srcs = [
        "package.json",
        ":browser-client_ts",
    ],
)
